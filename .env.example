# ── Frontend (Next.js — NEXT_PUBLIC_* vars are exposed to the browser) ──
# API base URL. Leave as /api — the Express API is mounted inside Next
# (same origin) in both dev and production.
NEXT_PUBLIC_API_URL=/api

# Google OAuth (must match GOOGLE_CLIENT_ID below)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Razorpay (must match RAZORPAY_KEY_ID below — use test key for development)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ── Server (Express API — mounted at /api inside Next) ─────────────

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/momentry

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret


CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret


PORT=5000
FRONTEND_URL=http://localhost:5173

ADMIN_URL=http://localhost:5174

